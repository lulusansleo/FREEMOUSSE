#!/usr/bin/env bash
# Enforces Conventional Commits format:
#   feat(render): add waveform oscilloscope
#   fix(audio): handle default device not found
#   perf(fft): cache plan across frames
MSG=$(cat "$1")
PATTERN='^(feat|fix|perf|refactor|docs|ci|chore)(\([a-z]+\))?: .{3,}'
if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "ERROR: commit message must follow Conventional Commits:"
  echo "  <type>(<scope>): <description>"
  echo "  types: feat | fix | perf | refactor | docs | ci | chore"
  echo ""
  echo "  e.g.: feat(render): add waveform oscilloscope"
  echo ""
  exit 1
fi
